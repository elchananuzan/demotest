# Demo mode — set to "true" to use generated demo data instead of Oref API
# NEXT_PUBLIC_DEMO_MODE=true

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Mapbox (optional — SVG fallback map works without it)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token

# Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@lionfury.live

# Push API protection
PUSH_API_KEY=your-secret-api-key

# Claude API (for Intelligence Brief page)
ANTHROPIC_API_KEY=sk-ant-your-key
